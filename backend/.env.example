# Chronify Backend Configuration
# ================================
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to git

# Server Configuration
PORT=5000
NODE_ENV=development
TRUST_PROXY=false

# Database
# MongoDB Atlas connection string
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?appName=<appname>
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/?appName=Cluster0

# Authentication
# Generate a strong random secret: openssl rand -base64 32
JWT_SECRET=your-super-secret-key-change-this
JWT_EXPIRES_IN=7d

# Third-party API Keys
# Get your key from https://platform.openai.com/api-keys/
OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# Local AI fallback (development only)
# true: generate a local plan when external AI APIs fail
# false: return provider errors directly
LOCAL_AI_FALLBACK=true

# AI request performance tuning (optional)
# Timeout per provider call in milliseconds
AI_PROVIDER_TIMEOUT_MS=12000
# Temporary cooldowns to skip providers after known hard failures
AI_CREDIT_COOLDOWN_MS=1800000
AI_AUTH_COOLDOWN_MS=1800000
AI_RATE_LIMIT_COOLDOWN_MS=20000

# Google Calendar Sync (Optional)
# 1) Create OAuth credentials in Google Cloud Console
# 2) Add redirect URI: http://localhost:5000/api/v1/auth/google-calendar/callback
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/v1/auth/google-calendar/callback
FRONTEND_URL=http://localhost:3000
# Parallel sync workers for Google Calendar batch sync
GOOGLE_SYNC_BATCH_CONCURRENCY=3
# Parallel workers for calendar event deletes
GOOGLE_SYNC_DELETE_BATCH_CONCURRENCY=3
# Retry behavior for transient Google API failures
GOOGLE_SYNC_RETRY_ATTEMPTS=3
GOOGLE_SYNC_RETRY_BASE_DELAY_MS=400

# Email Configuration (Optional)
# If not configured, emails will use a test service
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=Chronify <noreply@chronify.com>
